# Smarana v2 Backend - Environment Configuration Example
# Copy this file to .env and configure the variables as appropriate for your environment.

# Environment: "development" or "production"
ENVIRONMENT=development

# Database Connection URI (must use an asyncpg driver for sqlalchemy async support)
DATABASE_URL=postgresql+asyncpg://smarana_user:smarana_secure_pass_2026@localhost:5432/smarana_v2

# JSON Web Token settings
# Generate a secure key in terminal using: openssl rand -hex 32
JWT_SECRET=5bf891ef60d5b060ee4515579f12d8a0c4f8d95eb079c6d3bc8f504de0f9b634
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Allowed CORS Origins
# Pin this to your chrome-extension ID (e.g. chrome-extension://kdjfkdjfkdjfkdjfkdjfkdjf) in production.
# For multiple origins, separate them by commas: chrome-extension://<id>,http://localhost:3000
CORS_ORIGINS=*
