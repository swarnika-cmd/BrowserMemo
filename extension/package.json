{
  "name": "smarana-extension",
  "version": "2.0.0",
  "description": "Chrome Extension background script for local-first capture and encryption.",
  "scripts": {
    "build": "npm run build:dev",
    "build:dev": "esbuild src/background.ts src/content.ts src/popup.ts --bundle --outdir=dist --format=esm --target=chrome100 --define:process.env.API_URL='\"http://localhost:8000\"'",
    "build:prod": "esbuild src/background.ts src/content.ts src/popup.ts --bundle --outdir=dist --format=esm --target=chrome100 --minify --define:process.env.API_URL='\"https://api.smarana.app\"'",
    "watch": "esbuild src/background.ts src/content.ts src/popup.ts --bundle --outdir=dist --format=esm --target=chrome100 --watch --define:process.env.API_URL='\"http://localhost:8000\"'"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.263",
    "esbuild": "^0.20.1",
    "typescript": "^5.3.3"
  }
}
